<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@android:color/white"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Food image with edit FAB overlay -->
        <FrameLayout
            android:id="@+id/imageContainer"
            android:layout_width="0dp"
            android:layout_height="160dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/restaurantImageView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/image_placeholder"
                android:contentDescription="@string/restaurant_image"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium" />

            <!-- Mini FAB for Edit -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/editFab"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:contentDescription="@string/edit"
                app:fabSize="mini"
                app:fabCustomSize="48dp"
                app:maxImageSize="20dp"
                app:tint="@color/white"
                app:srcCompat="@drawable/ic_edit"
                app:elevation="4dp" />

        </FrameLayout>

        <!-- Restaurant name (tappable) -->
        <TextView
            android:id="@+id/restaurantNameTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="?attr/selectableItemBackground"
            android:textColor="@color/accent_caramel"
            android:textSize="16sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Golden Dragon"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/imageContainer" />

        <!-- Restaurant address (secondary line) -->
        <TextView
            android:id="@+id/restaurantAddressTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="888 Chinatown Plaza, Downtown"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/restaurantNameTextView" />

        <!-- Date -->
        <TextView
            android:id="@+id/dateTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:alpha="0.7"
            tools:text="Dec 28, 2024"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/restaurantAddressTextView" />

        <!-- Star rating (5-star row) -->
        <LinearLayout
            android:id="@+id/starRatingLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dateTextView">

            <ImageView
                android:id="@+id/star1ImageView"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_star_filled"
                android:contentDescription="@string/rating_star"
                android:layout_marginEnd="4dp"
                app:tint="@color/star_amber" />

            <ImageView
                android:id="@+id/star2ImageView"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_star_filled"
                android:contentDescription="@string/rating_star"
                android:layout_marginEnd="4dp"
                app:tint="@color/star_amber" />

            <ImageView
                android:id="@+id/star3ImageView"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_star_filled"
                android:contentDescription="@string/rating_star"
                android:layout_marginEnd="4dp"
                app:tint="@color/star_amber" />

            <ImageView
                android:id="@+id/star4ImageView"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_star_filled"
                android:contentDescription="@string/rating_star"
                android:layout_marginEnd="4dp"
                app:tint="@color/star_amber" />

            <ImageView
                android:id="@+id/star5ImageView"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_star_filled"
                android:contentDescription="@string/rating_star"
                app:tint="@color/star_amber" />

        </LinearLayout>

        <!-- Review text -->
        <TextView
            android:id="@+id/reviewTextView"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:lineSpacingMultiplier="1.2"
            tools:text="Incredible dim sum! The shrimp dumplings were perfectly steamed."
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/starRatingLayout" />

        <!-- Like / comment row -->
        <LinearLayout
            android:id="@+id/likesCommentsRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/reviewTextView">

            <ImageView
                android:id="@+id/likeButton"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_heart_outline"
                android:contentDescription="@string/likes_label"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/likeCountTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="12" />

            <ImageView
                android:id="@+id/commentButton"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginStart="16dp"
                android:src="@drawable/ic_comment_outline"
                android:contentDescription="@string/send_comment"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView
                android:id="@+id/tvCommentCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:text="0" />

        </LinearLayout>

        <!-- Delete button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/deleteButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/delete"
            android:textColor="#D32F2F"
            app:icon="@drawable/ic_delete"
            app:iconTint="#D32F2F"
            app:strokeColor="#D32F2F"
            app:strokeWidth="1dp"
            app:cornerRadius="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/likesCommentsRow" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

